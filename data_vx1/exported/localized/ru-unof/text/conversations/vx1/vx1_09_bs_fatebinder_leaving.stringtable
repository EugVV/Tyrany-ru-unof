<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\vx1\vx1_09_bs_fatebinder_leaving</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Ты все еще тут? Кто бы мог подумать".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Ничего тут нет для тебя интересного, Вершитель судеб".</DefaultText>
      <FemaleText>"Ничего тут нет для тебя интересного, Вершительница судеб".</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Я ничем не могу тебе помочь, Вершитель судеб".</DefaultText>
      <FemaleText>"Я ничем не могу тебе помочь, Вершительница судеб".</FemaleText>
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Уходи. Мне нечего тебе сказать".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>