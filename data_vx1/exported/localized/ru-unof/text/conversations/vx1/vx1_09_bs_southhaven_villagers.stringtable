<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\vx1\vx1_09_bs_southhaven_villagers</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Приветствую, Вершитель судеб. Мы тут славные люди. Все любим Владыку».</DefaultText>
      <FemaleText>«Приветствую, Вершительница судеб. Мы тут славные люди. Все любим Владыку».</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Добро пожаловать в Южную Гавань».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Лично я считаю, Скованным Горном не следует никуда уходить!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Говорят, ты наверху Шпиля был. А оттуда Кайроса видно?»</DefaultText>
      <FemaleText>«Говорят, ты наверху Шпиля была. А оттуда Кайроса видно?»</FemaleText>
    </Entry>
  </Entries>
</StringTableFile>
