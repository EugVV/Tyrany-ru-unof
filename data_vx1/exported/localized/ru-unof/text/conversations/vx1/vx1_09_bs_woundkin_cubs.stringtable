<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\vx1\vx1_09_bs_woundkin_cubs</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Пахнет как свой, но волос нет».</DefaultText>
      <FemaleText>«Пахнет как своя, но волос нет».</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Почему у людей нет шерсти?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Мать стаи говорит, у мелкого большие острые когти!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Ар-р-р-р! Р-р-р! Мелкий напугал человека, да?»</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
