<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\worldevents\00_bs_randomrebels2</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Мы пришли отомстить за павших. Мы жаждем твоей крови!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"За Оплот!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Тебе нас не покорить, шавка Кайроса!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Мы не забываем тех, кто переходит нам дорогу, Вершитель. И ты поплатишься".</DefaultText>
      <FemaleText>"Мы не забываем тех, кто переходит нам дорогу, Вершительница. И ты поплатишься".</FemaleText>
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>"Я тебе башку снесу, твою мать!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>