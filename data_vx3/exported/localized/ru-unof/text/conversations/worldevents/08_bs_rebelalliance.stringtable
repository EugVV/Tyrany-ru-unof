<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\worldevents\08_bs_rebelalliance</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Это не наша драка, Вершитель. Ну их всех".</DefaultText>
      <FemaleText>"Это не наша драка, Вершительница. Ну их всех".</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Проклятье, нет! Мы все вместе должны противостоять Кайросу!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"За королеву и за Ярусы!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Иди, закончи начатое, северная шавка!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>