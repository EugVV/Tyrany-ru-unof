<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_disfavoredcamp_adjudication_falx_sc_soldier</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Вершитель, этот железный пень ведет себя, как последний кретин. Ты нам не поможешь?"</DefaultText>
      <FemaleText>"Вершительница, этот железный пень ведет себя, как последний кретин. Ты нам не поможешь?"</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"В последний раз прошу помощи у суда..."</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Клинок моих предков! Я буду носить его с честью".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Даже если мне достанется старая, ржавая кочерга, это лучше, чем ничего".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Ну что, у тебя нет для меня никаких новостей? Нет?"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>