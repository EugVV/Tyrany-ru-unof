<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_companion_wallabouttobedestroyed</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Книгочеи погибли! Стена не выстоит перед латниками Аше!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Умники пошли на корм воронью. Теперь [url=glossary:опальные]Опальные[/url] спокойно возьмут стену".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Мои коллеги погибли. Теперь [url=glossary:опальные]Опальные[/url] с легкостью вскроют нашу оборону".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Книгочеи мертвы. Теперь ничто не сможет помешать Опальным пробить эту стену. Разумеется, кроме самой стены".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>