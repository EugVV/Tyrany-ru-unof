  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>Маг мрачно вам кивает.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Если ты не возражаешь, мне следует позаботиться о солдатах и моих несчастных собратьях».</DefaultText>
      <FemaleText />
