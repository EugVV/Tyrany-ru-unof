  <Name>conversations\08_vendrienswell\08_bs_secret_meeting_guard</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>2</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Вершитель судеб, Таркис Арри ждет! Следуй за мной».</DefaultText>
      <FemaleText>«Вершительница судеб, Таркис Арри ждет! Следуй за мной».</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Таркис Арри ожидает тебя наверху. Мы будем за тобой приглядывать».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
