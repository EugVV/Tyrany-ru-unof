<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_scarletchoruscamp_matani_prisoner</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Если уж мне суждено умереть, я хочу умереть спокойно».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«[url=glossary:гвардия вендриенов]Гвардия Вендриенов[/url] сражается за то, что принадлежит им по праву, а за что сражаешься ты?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Хватит, отвали!»</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
