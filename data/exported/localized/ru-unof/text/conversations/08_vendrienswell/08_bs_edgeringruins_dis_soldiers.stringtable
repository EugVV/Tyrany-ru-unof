<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_edgeringruins_dis_soldiers</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Просто возмутительно, что нам приходится делить поле боя со всем этим сбродом из Алого Хора".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Слава Грэйвену Аше! Слава Кайросу!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>Солдат из Опальных приветствует вас сдержанным кивком.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Если кто-то из Хора будет доставлять хлопоты, дайте мне знать — я готов проломить пару черепов".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>