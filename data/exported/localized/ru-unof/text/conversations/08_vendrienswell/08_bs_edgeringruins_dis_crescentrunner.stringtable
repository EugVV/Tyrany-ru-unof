<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_edgeringruins_dis_crescentrunner</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>7</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Скорее!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Они схватили Драстуса!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Нельзя медлить!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Спасибо за помощь, Вершитель».</DefaultText>
      <FemaleText>«Спасибо за помощь, Вершительница».</FemaleText>
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>«Мы проучим этих клятвопреступников!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>«Да пребудет с вами Мир Кайроса».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
