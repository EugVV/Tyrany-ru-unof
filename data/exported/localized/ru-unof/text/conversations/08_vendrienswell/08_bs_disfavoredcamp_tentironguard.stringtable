<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_disfavoredcamp_tentironguard</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Вершитель судеб! Архонты ждут вас внутри».</DefaultText>
      <FemaleText>«Вершительница судеб! Архонты ждут вас внутри».</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Ты это слышал?»</DefaultText>
      <FemaleText>«Ты это слышала?»</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Похоже на [url=glossary:эдикт]Эдикт[/url]. Наверное, Владыка устал ждать».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Вот что получаешь, когда приходится работать с упырями из Хора».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
