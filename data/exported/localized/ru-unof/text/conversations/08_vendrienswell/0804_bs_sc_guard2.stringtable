<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\0804_bs_sc_guard2</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Я должен быть начеку. Могут показаться враги».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Иди доставай кого-нибудь еще. Не мешай мне концентрироваться».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Ты что, не видишь, что мы заняты? От стояния в дозоре такая жажда просыпается…»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>Солдат демонстративно вас не замечает.</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
