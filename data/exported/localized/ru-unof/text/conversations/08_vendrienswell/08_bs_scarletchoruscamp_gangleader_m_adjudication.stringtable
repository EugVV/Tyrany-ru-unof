<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_scarletchoruscamp_gangleader_m_adjudication</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>Заляпанный кровью хорист мрачно вам кивает.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Уму непостижимо. У нас есть проблемы и поважнее!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Я чего, должен сказать спасибо или куда?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>Солдат вам кивает.</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
