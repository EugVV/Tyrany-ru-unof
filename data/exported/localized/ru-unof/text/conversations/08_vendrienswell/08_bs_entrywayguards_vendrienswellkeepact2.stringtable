<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_entrywayguards_vendrienswellkeepact2</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Дела тут становятся все хуже и хуже».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Будь осторожен там, Вершитель».</DefaultText>
      <FemaleText>«Будь осторожна там, Вершительница».</FemaleText>
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Приветствую, Вершитель!».</DefaultText>
      <FemaleText>«Приветствую, Вершительница!».</FemaleText>
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Все спокойно, Вершитель».</DefaultText>
      <FemaleText>«Все спокойно, Вершительница».</FemaleText>
    </Entry>
  </Entries>
</StringTableFile>
