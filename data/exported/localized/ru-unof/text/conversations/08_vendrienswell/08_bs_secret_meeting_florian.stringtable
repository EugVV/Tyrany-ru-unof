<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_secret_meeting_florian</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Рад снова видеть тебя, Вершитель. Я твой должник".</DefaultText>
      <FemaleText>"Рад снова видеть тебя, Вершительница. Я твой должник".</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Поговори с Таркис Арри. Времени у нас осталось немного".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Закончил нас дразнить? Уходи, пока не начались проблемы".</DefaultText>
      <FemaleText>"Закончила нас дразнить? Уходи, пока не начались проблемы".</FemaleText>
    </Entry>
  </Entries>
</StringTableFile>