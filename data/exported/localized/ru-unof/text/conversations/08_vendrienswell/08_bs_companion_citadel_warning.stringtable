<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_companion_citadel_warning</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Идем, Вершитель! У нас мало времени!»</DefaultText>
      <FemaleText>«Идем, Вершительница! У нас мало времени!»</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«[url=glossary:эдикт]Эдикт[/url] ждать не станет! Мы должны попасть в [url=glossary:зал вознесения]Зал Вознесения[/url]!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Шевели булками, нужно добраться до Зала Вознесения!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
