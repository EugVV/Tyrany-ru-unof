<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_disfavoredcamp_prisonguard</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>2</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Никто не должен разговаривать с пленниками. Я получил четкий приказ».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«У клятвопреступников уже был шанс — нет смысла тратить место в камерах на тех, кто предал Кайроса».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
