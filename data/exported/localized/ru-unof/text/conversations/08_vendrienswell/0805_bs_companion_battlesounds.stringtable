  <Entries>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Я слышу музыку битвы. Мы не должны терять времени!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Слышишь? Бой уже начался".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Бой идет без нас? Вперед!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
