<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_cv_scarletchoruscamp_prisonerguard</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Без разрешения Пятого Глаза к пленникам подходить нельзя!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Отойди от пленника!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Можешь подойти к пленнику".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Солдат, пусть Вершитель судеб побеседует с нашим уловом".</DefaultText>
      <FemaleText>"Солдат, пусть Вершительница судеб побеседует с нашим уловом".</FemaleText>
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Хорошо".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
