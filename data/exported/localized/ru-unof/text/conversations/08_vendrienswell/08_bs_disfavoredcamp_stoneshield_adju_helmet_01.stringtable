<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\08_vendrienswell\08_bs_disfavoredcamp_stoneshield_adju_helmet_01</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>5</ID>
      <DefaultText>"У нас все под контролем, Вершитель судеб".</DefaultText>
      <FemaleText>"У нас все под контролем, Вершительница судеб".</FemaleText>
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>"[url=glossary:опальные]Опальные[/url] редко прощают такие преступления, Вершитель".</DefaultText>
      <FemaleText>"[url=glossary:опальные]Опальные[/url] редко прощают такие преступления, Вершительница".</FemaleText>
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>"Мы благодарны тебе за помощь, Вершитель судеб".</DefaultText>
      <FemaleText>"Мы благодарны тебе за помощь, Вершительница судеб".</FemaleText>
    </Entry>
  </Entries>
