<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\companions\companion_bs_eb_terratusgrip</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Давайте, корчьтесь… да… вот так… М-м-м…"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Теперь у меня есть ты".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Не так быстро… Я собираюсь немного с тобой развлечься".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Вот такой я предпочитаю видеть добычу — скованной и беспомощной".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Добро пожаловать на страшный суд, смерть и увечья интересуют?"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>