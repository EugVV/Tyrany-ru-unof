<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\05_cairnplains\05_bs_skypillarbase_beastman_02</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Каменные земли принадлежат племени. Всегда принадлежали и будут принадлежать!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>Он нюхает вас, а затем громко фыркает.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Если будет нужно, [url=glossary:камнепыты]Камнепыты[/url] защитят территорию племени и прольют кровь – а гладкокожие будут кричать, пока не охрипнут".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>