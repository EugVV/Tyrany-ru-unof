<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\05_cairnplains\05_cv_settler_beastcrowd_bark_01</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>13</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Убей зверя! Они бы с нами не церемонились, если б поймали!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Чего ты ждешь? Убей чудовище!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Золотое кольцо тому, кто принесет мне его отрубленную лапу!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Этот дикарь убил моих родных!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Содрать с него шкуру!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>8</ID>
      <DefaultText>"Зверь на свободе? Теперь мы обречены!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>9</ID>
      <DefaultText>"Не подпускайте эту тварь к моим детям!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>10</ID>
      <DefaultText>"Это сделал Вершитель судеб? Какой позор!"</DefaultText>
      <FemaleText>"Это сделала Вершительница судеб? Какой позор!"</FemaleText>
    </Entry>
    <Entry>
      <ID>11</ID>
      <DefaultText>"Уберите этого дикаря из нашего города!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>12</ID>
      <DefaultText>"Это [Plainsgate], здесь так дела не делают!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>13</ID>
      <DefaultText>"Отвратительно! Эти твари не должны быть на свободе".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>