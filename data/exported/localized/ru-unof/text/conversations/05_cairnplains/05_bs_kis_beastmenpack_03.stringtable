<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\05_cairnplains\05_bs_kis_beastmenpack_03</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>2</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Стае теперь нужно охотиться без нее, без силы Охотницы Тени. Но мы многому научились от Смерти-из-тени".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>Он нюхает вас, а затем громко фыркает.</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>