<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\03_burninglibrary\0302_bs_beastman_guard</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Человек не пройдет зверолюда. Нельзя видеть пойманную добычу».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Назад. Уходи на обеих ногах».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>Зверолюд рычит на вас.</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
