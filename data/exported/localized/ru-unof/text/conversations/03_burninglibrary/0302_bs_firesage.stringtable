<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\03_burninglibrary\0302_bs_firesage</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Со всеми вопросами лучше обращайся к Ренате».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Мне правда нечего тебе предложить».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Не ищи неприятностей, Вершитель».</DefaultText>
      <FemaleText>«Не ищи неприятностей, Вершительница».</FemaleText>
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Ты очень далеко от суда, Вершитель».</DefaultText>
      <FemaleText>«Ты очень далеко от суда, Вершительница».</FemaleText>
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Смотри у меня».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
