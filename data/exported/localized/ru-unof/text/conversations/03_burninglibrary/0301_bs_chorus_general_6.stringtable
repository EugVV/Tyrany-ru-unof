<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\03_burninglibrary\0301_bs_chorus_general_6</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Мы следим за тобой, Вершитель. Одно неверное движение – и ты труп".</DefaultText>
      <FemaleText>"Мы следим за тобой, Вершительница. Одно неверное движение – и ты труп".</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Книгочеи – твари хитрые. Никогда не задерживаются надолго на одном месте".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Что скажешь, Вершитель? Цеплять на Книгочеев намордники или ошейников хватит?"</DefaultText>
      <FemaleText>"Что скажешь, Вершительница? Цеплять на Книгочеев намордники или ошейников хватит?"</FemaleText>
    </Entry>
  </Entries>
</StringTableFile>