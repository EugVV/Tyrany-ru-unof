<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\03_burninglibrary\0301_bs_binders_general_3</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Все знания, что мы найдем здесь — к твоим услугам. Это самое малое, что мы можем сделать".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Мы долго ждали этого дня".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Какое облегчение избавиться от всех этих углей! Когда-нибудь доводилось просыпаться от того, что на тебе горит одежда? Неприятно".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>