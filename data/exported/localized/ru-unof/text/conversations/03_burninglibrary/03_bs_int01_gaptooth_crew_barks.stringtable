  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Щербатой нужно решиться! Я хочу убивать!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Я жажду боя! Идем!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Пока мы тут ждем, другая группа может выиграть!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Одно слово Щербатой – и ты труп…"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
