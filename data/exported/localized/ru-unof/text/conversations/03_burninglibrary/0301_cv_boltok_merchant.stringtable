<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\03_burninglibrary\0301_cv_boltok_merchant</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Приветствую, Вершитель судеб! Пришел взглянуть на товар?"</DefaultText>
      <FemaleText>"Приветствую, Вершительница судеб! Пришла взглянуть на товар?"</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Давай посмотрим, что у тебя есть".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Прощай".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"С возвращением, Вершитель судеб! Чего изволите?"</DefaultText>
      <FemaleText>"С возвращением, Вершительница судеб! Чего изволите?"</FemaleText>
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Уходи".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>