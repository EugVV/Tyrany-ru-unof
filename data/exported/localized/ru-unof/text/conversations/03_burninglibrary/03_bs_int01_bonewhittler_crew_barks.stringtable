<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\03_burninglibrary\03_bs_int01_bonewhittler_crew_barks</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Мне здесь нравится..."</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Ну, с кем там сражаться дальше? Мне скучно стоять просто так".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"От этой жары вскипает кровь".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Точно не хочешь начать уже что-нибудь делать?"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>