<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\02_bs_lc_merchant_02_ambientbarks</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Кто-то видел эту вспышку света на Шпиле?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Говорят, зажегся не только наш Шпиль, но и другие Шпили в Ярусах. Интересно, что это может значить?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Надеюсь, теперь в [url=glossary:распутье летианы]Распутье Летианы[/url] наконец-то вернется мир…»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Кто защитит наши лавки, если гарнизона больше нет?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>«Теперь, когда нас защищает [url=glossary:гвардия вендриенов]Гвардия Вендриенов[/url], мне дышится свободней».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
