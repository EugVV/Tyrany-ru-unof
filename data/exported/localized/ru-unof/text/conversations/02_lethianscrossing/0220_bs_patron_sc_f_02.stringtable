<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\0220_bs_patron_sc_f_02</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Уходи. Мне и без тебя есть чем заняться, а ты все испортишь, если будешь тут торчать».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Да что за… Почему не вставляется… Может, если вот так развернуть?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Если так и будешь торчать тут и пялиться, я с тебя деньги за просмотр брать начну».</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
