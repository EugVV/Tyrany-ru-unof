<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\0220_bs_patron_sc_m_01</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Скажем прямо — я тут слишком много трачу, но она того стоит, правда".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Если хочешь снять Эваристу, становись в очередь. Она умеет доставлять удовольствие!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Если будет возможность, «Железное долбило» у нее закажи. Круче не бывает!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Эй, тихо! Не раскрывай все мои секреты!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>