<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\02_bs_concerned_settlers</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Что мы будем делать без Шлема Магоборца?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Надеюсь, у Элдиана есть план, который поможет нам вернуть шлем".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Если мы не вернем шлем, то кто защитит нас от погибелей?"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>