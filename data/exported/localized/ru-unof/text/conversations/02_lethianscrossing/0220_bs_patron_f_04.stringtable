<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\0220_bs_patron_f_04</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Чего бы мне сегодня хотелось? О, муки выбора..."</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"С одной стороны, Фило куда хочешь дотянется, во все места..."</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"...Но, с другой, Щедритус такой ласковый, с ним прямо благородной дамой себя чувствуешь".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>