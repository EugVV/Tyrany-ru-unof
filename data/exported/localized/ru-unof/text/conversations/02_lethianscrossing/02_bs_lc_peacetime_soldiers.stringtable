<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\02_bs_lc_peacetime_soldiers</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>8</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"К бою – Вершитель судеб явился! Поднимайте мосты!"</DefaultText>
      <FemaleText>"К бою – Вершительница судеб явилась! Поднимайте мосты!"</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Погибели вырвались из ловушек!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>Завидев вас, караульные вытягиваются по стойке смирно. Один из них обращается к вам.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>"Добро пожаловать в [url=glossary:распутье летианы]Распутье Летианы[/url], Вершитель судеб".</DefaultText>
      <FemaleText>"Добро пожаловать в [url=glossary:распутье летианы]Распутье Летианы[/url], Вершительница судеб".</FemaleText>
    </Entry>
    <Entry>
      <ID>8</ID>
      <DefaultText>"Будь начеку. Враг может ударить в любой момент".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>