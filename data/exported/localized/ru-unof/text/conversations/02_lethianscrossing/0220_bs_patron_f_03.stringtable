<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\02_lethianscrossing\0220_bs_patron_f_03</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Ты на эти волосы погляди. Ох, до чего блондинов люблю. У меня от них крышу сносит!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Ты глянь, как он двигается! Как классно танцует. Да, такой мужик тебя вспашет, как надо!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"А что, если... Или лучше нет. Никак не могу решить!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>