  <Name>conversations\factionquestlines\disfavored\fq_dis_cv_01_pelagus_sentinelstandkeep</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>2</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Вершитель судеб, ты оказал Скаловержцам очень большую услугу, которую мы никогда не забудем".</DefaultText>
      <FemaleText>"Вершительница судеб, ты оказала Скаловержцам очень большую услугу, которую мы никогда не забудем".</FemaleText>
    </Entry>
    <Entry>
      <ID>9</ID>
      <DefaultText>"Рад снова тебя видеть, Вершитель. Что тебе нужно?"</DefaultText>
      <FemaleText>"Рад снова тебя видеть, Вершительница. Что тебе нужно?"</FemaleText>
    </Entry>
  </Entries>
</StringTableFile>