<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\00_stronghold\00_recruits\00_cv_vendrienswell_skilltrainer_swordbreaker</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Крепко держи оружие и не отступай. Если тебя разоружили, продолжай сражаться – или умрешь. Таков путь воина".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Я бы хотел потренироваться".</DefaultText>
      <FemaleText>"Я бы хотела потренироваться".</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Прощай".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Что-нибудь нужно?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Что ж, сразимся – но в духе инструкций".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>