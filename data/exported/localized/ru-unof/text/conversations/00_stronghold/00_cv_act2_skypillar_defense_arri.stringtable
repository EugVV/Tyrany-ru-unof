<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\00_stronghold\00_cv_act2_skypillar_defense_arri</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Что нам делать, Вершитель судеб?"</DefaultText>
      <FemaleText>"Что нам делать, Вершительница судеб?"</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"С этим нужно разобраться. Идем поговорим с ними".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Пусть подождут. Я еще не готов".</DefaultText>
      <FemaleText>"Пусть подождут. Я еще не готова".</FemaleText>
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Их слишком много. Стены их надолго не удержат".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>