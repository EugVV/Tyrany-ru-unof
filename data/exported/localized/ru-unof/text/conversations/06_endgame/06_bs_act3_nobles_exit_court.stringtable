<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\06_endgame\06_bs_act3_nobles_exit_court</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"На сегодня прием вельмож закончен. Суд завершает работу".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Это возмутительно, мы требуем, чтобы нас выслушали!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Этот указ не подлежит обсуждению. Приставы проводят всех вас к выходу".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>