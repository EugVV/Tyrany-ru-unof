<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\06_endgame\06_cv_scarletchorusfort_store</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Приветствую, Вершитель. Желаешь взглянуть на мои товары?»</DefaultText>
      <FemaleText>«Приветствую, Вершительница. Желаешь взглянуть на мои товары?»</FemaleText>
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Давай посмотрим, что у тебя есть».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Не сейчас».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>«С возвращением, Вершитель. Желаешь что-нибудь приобрести?»</DefaultText>
      <FemaleText>«С возвращением, Вершительница. Желаешь что-нибудь приобрести?»</FemaleText>
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>«Вам что-нибудь понравилось, Архонт? Хотите что-нибудь купить?»</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
