  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Какие вы наивные…"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Раздели наши кошмары".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Хочешь узнать тайну?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>[Маниакальный смех.]</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Твой разум что игрушка для меня".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>"Внемли, когда говорит вечность!"</DefaultText>
      <FemaleText />
