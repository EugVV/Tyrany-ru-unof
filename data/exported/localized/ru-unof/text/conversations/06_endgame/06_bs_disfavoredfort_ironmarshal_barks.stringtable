<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\06_endgame\06_bs_disfavoredfort_ironmarshal_barks</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>17</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Генерал... Генерал! Что они с вами сделали?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>Железный Маршал сжимает кулаки и стискивает зубы.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Север запомнит это оскорбление!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Рада, что вы с нами, Архонт".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>"Нам нужен сильный лидер, и это относится к Аше тоже".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>"Подумай только о нашем героическом возвращении на Север!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>8</ID>
      <DefaultText>"Вершитель. У меня много работы. Поговори с Аше, если тебе что-то нужно".</DefaultText>
      <FemaleText>"Вершительница. У меня много работы. Поговори с Аше, если тебе что-то нужно".</FemaleText>
    </Entry>
    <Entry>
      <ID>9</ID>
      <DefaultText>Железный Маршал смотрит на вас с неприязнью.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>10</ID>
      <DefaultText>"Я смогу... это выдержать".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>11</ID>
      <DefaultText>Железный Маршал прикрывает рот, сдерживая рвотные позывы.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>12</ID>
      <DefaultText>"Такое ощущение, что мое тело гниет".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>13</ID>
      <DefaultText>"Сколько еще терпеть эту боль?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>14</ID>
      <DefaultText>"Аше... если бы вы могли нам помочь..."</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>15</ID>
      <DefaultText>"Аше! Мы страдаем без вас!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>16</ID>
      <DefaultText>Железный Маршал рыдает, не в силах сдерживаться.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>17</ID>
      <DefaultText>"Я едва могу выдержать вес своего доспеха".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>