  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Похоже, пора менять тактику".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Так мало тебя, так много нас... нечестно, правда?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Подожди, не сдавайся... мы еще не все тебе показали!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Мы ведь только начали!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Тебе придется убить нас ВСЕХ!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
