<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_bs_forgebound_rustcanyons</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"[url=glossary:грэйвен аше]Грэйвен Аше[/url] принесет закон и порядок в эти дикие земли. Я верю".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Обитатели Ярусов глупцы. Они сами отказались от Мира Кайроса".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>"Как еще научить разбойников закону, если не с помощью мечей и публичных казней?"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>"Это не моя война. Я просто чиню доспехи".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>