<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_bs_mattias_sentinelstand</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Ни шагу назад! Мы должны прогнать их — раз и навсегда!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Возглавляй атаку, Вершитель! Мы позаботимся, чтобы никто не обошел тебя с флангов".</DefaultText>
      <FemaleText>"Возглавляй атаку, Вершительница! Мы позаботимся, чтобы никто не обошел тебя с флангов".</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Ради Оплота и Несломленных, мы выстоим!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>