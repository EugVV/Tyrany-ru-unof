<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_poi_oldwall_01_emerging_dead</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>7</EntryCount>
  <Entries>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Бичеватели! Нужно действовать быстро, пока нас не задавили!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Держитесь, нас окружают хищники!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Мы можем бежать, но вряд ли сможем скрыться от этих существ».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Стая должна нападать, как хищники, а не убегать, как добыча!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>«Подходите поближе, уродливые ублюдки!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>8</ID>
      <DefaultText>«Берегись! Нам нужно разобраться с бичевателями!»</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
