  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Враг у главных ворот! Не пропускайте никого!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Все сюда! Стены под атакой!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Идите вперёд и удерживайте позиции!»</DefaultText>
      <FemaleText />
