<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\0101_bs_dis_ally_02</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Жаль, мне не удалось полюбоваться на бойню. Ты хорошо поработал, Вершитель судеб".</DefaultText>
      <FemaleText>"Жаль, мне не удалось полюбоваться на бойню. Ты хорошо поработала, Вершительница судеб".</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Мой дом — там, где сейчас находится легион".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Враги Кайроса на своей шкуре почувствуют остроту Опальных клинков".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Надеюсь, каждый из нас погибнет в честном бою".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>