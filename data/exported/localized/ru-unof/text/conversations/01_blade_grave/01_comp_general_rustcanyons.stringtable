<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_comp_general_rustcanyons</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Скорее к восточным воротам, пока мы их удерживаем!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Слышал это? Враги у западных ворот!"</DefaultText>
      <FemaleText>"Слышала это? Враги у западных ворот!"</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Подкрепления врага идут с севера! Нет времени медлить!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Подкрепления, за нами!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>