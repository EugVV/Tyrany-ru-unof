  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Уходи, или мы тебя заставим".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Добро пожаловать, Вершитель судеб. Проходи внутрь".</DefaultText>
      <FemaleText>"Добро пожаловать, Вершительница судеб. Проходи внутрь".</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Гость у ворот! Не похож на человека Аше".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
