<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_bs_sc_soldier_01_trappersjunction</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Если хочешь поговорить с нашим главарем, Целебный Нож в лагере к югу отсюда».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Добро пожаловать, Вершитель судеб. Целебный Нож будет рад с тобой поболтать».</DefaultText>
      <FemaleText>«Добро пожаловать, Вершительница судеб. Целебный Нож будет рад с тобой поболтать».</FemaleText>
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Смерть Вершителю!»</DefaultText>
      <FemaleText>«Смерть Вершительнице!»</FemaleText>
    </Entry>
  </Entries>
</StringTableFile>
