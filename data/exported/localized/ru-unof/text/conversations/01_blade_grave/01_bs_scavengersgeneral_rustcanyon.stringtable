<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_bs_scavengersgeneral_rustcanyon</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>5</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Не подходи, незнакомец. Чужаков дальше не пускаем».</DefaultText>
      <FemaleText>«Не подходи, незнакомка. Чужаков дальше не пускаем».</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Стой! Ты не враг нам, но мы удерживаем этот мост не просто так».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>«Спасибо тебе!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText>«Возвращайся туда, откуда пришел, пока не начались проблемы».</DefaultText>
      <FemaleText>«Возвращайся туда, откуда пришла, пока не начались проблемы».</FemaleText>
    </Entry>
    <Entry>
      <ID>8</ID>
      <DefaultText>«Тебя предупреждали!»</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
