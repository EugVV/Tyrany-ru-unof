<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\0115_cv_mattias</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>3</EntryCount>
  <Entries>
    <Entry>
      <ID>20</ID>
      <DefaultText>"Боюсь, я знаю причину того, что бури не прекращаются…"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>21</ID>
      <DefaultText>"Давай покончим с этим, Вершитель судеб".</DefaultText>
      <FemaleText>"Давай покончим с этим, Вершительница судеб".</FemaleText>
    </Entry>
    <Entry>
      <ID>22</ID>
      <DefaultText>"Я не ожидал, что все так закончится, но Оплоту будет лучше".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>