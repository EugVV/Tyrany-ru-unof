<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_poi_unbroken_prisoners</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>7</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Слышишь? Из той ямы зовут на помощь… Подозреваю, что это пленники".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"[url=glossary:несломленные]Несломленные[/url] держали в этой яме пленников".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>8</ID>
      <DefaultText>"Из той дыры доносится визг. И вонь".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>9</ID>
      <DefaultText>"Вон, в яме. Наверняка пленники".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>10</ID>
      <DefaultText>"Вершитель судеб, в этой яме держали пленников".</DefaultText>
      <FemaleText>"Вершительница судеб, в этой яме держали пленников".</FemaleText>
    </Entry>
    <Entry>
      <ID>11</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>12</ID>
      <DefaultText>"Кто бы ни сидел в той дыре, они хотят выбраться наружу".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>