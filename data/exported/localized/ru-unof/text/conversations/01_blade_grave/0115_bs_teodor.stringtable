<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\0115_bs_teodor</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>4</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"У вас с Грэйвеном Аше уже был разговор о его дочери? Как же я не завидую такому заданию..."</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"Последний из регентов падет от нашей руки, забрав этот [url=glossary:эдикт]Эдикт[/url] с собой!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Твердыня Часовых наша! [url=glossary:опальные]Опальные[/url] не забудут этот славный миг".</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>"Что-то не так. Я это чувствую".</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>