<?xml version="1.0" encoding="utf-8"?>
<StringTableFile xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>conversations\01_blade_grave\01_poi_oldwall_01_more_dead</Name>
  <NextEntryID>1</NextEntryID>
  <EntryCount>7</EntryCount>
  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>«Они опять лезут. Готовься, Вершитель!»</DefaultText>
      <FemaleText>«Они опять лезут. Готовься, Вершительница!»</FemaleText>
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>«Сейчас будет продолжение!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>«Довольно с тебя? Если нет — то скоро будет добавка».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4</ID>
      <DefaultText>«Это еще не конец. Я не чувствую страха, а ты?»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>5</ID>
      <DefaultText>«Слышу, как существа приближаются, крадутся поближе! Быстро присаживайся, чтобы наброситься на них».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>6</ID>
      <DefaultText>«Похоже, мы перебили не всех! Готовимся!»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>7</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>
