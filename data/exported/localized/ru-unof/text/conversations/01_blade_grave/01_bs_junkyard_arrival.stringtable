  <Entries>
    <Entry>
      <ID>1</ID>
      <DefaultText>"Прирежьте этих ублюдков, ради своих матерей!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2</ID>
      <DefaultText>"На нас напали! Хватайте оружие!"</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3</ID>
      <DefaultText>"Это те ублюдочные подонки, которые напали на наш лагерь!"</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
