      <DefaultText>Обезвредить ловушку</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>1525</ID>
      <DefaultText>Поставить ловушку</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
