    <Entry>
      <ID>2517</ID>
      <DefaultText>ЗАТЫЧКА</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2518</ID>
      <DefaultText>ЗАТЫЧКА</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2519</ID>
      <DefaultText>ЗАТЫЧКА</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2520</ID>
      <DefaultText>Перезагрузка</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2521</ID>
      <DefaultText>Сущность Каирна</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2522</ID>
      <DefaultText>В предплечье Каирна содержится сущность силы.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2523</ID>
      <DefaultText>В глазе Каирна содержится сущность стойкости.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2524</ID>
      <DefaultText>В голове Каирна содержится сущность смекалки.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2525</ID>
      <DefaultText>В сердце Каирна содержится сущность живучести.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2526</ID>
      <DefaultText>В левой руке Каирна содержится сущность искусности.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2527</ID>
      <DefaultText>В правой руке Каирна содержится сущность быстроты.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2528</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2529</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2530</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2531</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2532</ID>
      <DefaultText>{0} {1} по цели: {2} ({3} {4}) при вступлении в бой.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2533</ID>
      <DefaultText>Метательное оружие</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2534</ID>
      <DefaultText />
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2536</ID>
      <DefaultText />
      <FemaleText />
