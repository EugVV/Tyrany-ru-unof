      <ID>3969</ID>
      <DefaultText>Необходимые рабочие ({0}): {1}</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3970</ID>
      <DefaultText>[Достаточно репутации]</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3972</ID>
      <DefaultText>Снятие штрафа к восстановлению при смене оружия</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3973</ID>
      <DefaultText>Промах: {0}%</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
