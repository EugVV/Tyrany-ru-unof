      <ID>3963</ID>
      <DefaultText>Исцеление союзников при поражении</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3964</ID>
      <DefaultText>Устранение негативного эффекта при убийстве</DefaultText>
      <FemaleText />
    </Entry>
