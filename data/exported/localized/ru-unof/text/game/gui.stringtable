      <ID>3965</ID>
      <DefaultText>Увеличение скорости передвижения в бою</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3966</ID>
      <DefaultText>Даёт эффект заклинания «Каменное оружие»</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
