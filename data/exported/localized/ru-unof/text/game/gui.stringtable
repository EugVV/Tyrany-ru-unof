      <DefaultText>Каменистый спуск</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>3711</ID>
      <DefaultText>Осторожно спуститься по каменистому спуску.</DefaultText>
      <FemaleText />
    </Entry>
