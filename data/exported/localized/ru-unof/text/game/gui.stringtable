      <ID>4140</ID>
      <DefaultText>Защита: {0}</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>4141</ID>
      <DefaultText>Управление: {0}</DefaultText>
      <FemaleText />
    </Entry>
