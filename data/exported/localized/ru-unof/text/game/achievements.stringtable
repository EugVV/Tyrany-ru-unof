      <FemaleText />
    </Entry>
    <Entry>
      <ID>28</ID>
      <DefaultText>В тени</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>29</ID>
      <DefaultText>Совместными усилиями</DefaultText>
      <FemaleText />
