      <FemaleText />
    </Entry>
    <Entry>
      <ID>2033</ID>
      <DefaultText>Дождь стрел</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2059</ID>
      <DefaultText>Сокращает восстановление и даёт меткость попадания при ранении.</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2060</ID>
      <DefaultText>До смерти</DefaultText>
      <FemaleText />
