      <DefaultText>Ржавый дротик</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>2026</ID>
      <DefaultText>В начале боя урон ближайших бойцов отряда уменьшается на 75%.</DefaultText>
      <FemaleText />
